# OpenAI API Key (For verification agent & chat)
OPENAI_API_KEY=your-openai-api-key

# Google Vision API Key (For OCR service)
GOOGLE_VISION_API_KEY=your-google-vision-api-key

# Angilo API Key (Optional custom scanning API)
ANGILO_API_KEY=your-angilo-api-key

# Server Settings
PORT=5000

# Authentication & Database
MONGO_URI=mongodb://localhost:27017/docufast
JWT_SECRET=use-a-strong-random-secret-key-in-production
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
